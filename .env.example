# =============================================================================
# Delivery Bot — environment variables namunasi.
# Real qiymatlarni `.env` fayliga ko'chiring (`.gitignore`'da, commit qilinmaydi).
# =============================================================================

# ----- Brend (MAJBURIY) -----
# Botlar va Mini App'larda salomlashish, sarlavhalar uchun ishlatiladi.
BRAND_NAME=Akilawater

# ----- Telegram bot tokenlari (MAJBURIY) -----
# @BotFather'da 3 ta alohida bot yarating va tokenlarni shu yerga yozing.
CUSTOMER_BOT_TOKEN=1234567890:AAA-replace-me-replace-me-replace-me
ADMIN_BOT_TOKEN=1234567890:BBB-replace-me-replace-me-replace-me
COURIER_BOT_TOKEN=1234567890:CCC-replace-me-replace-me-replace-me

# ----- Kuryerlar guruhi (MAJBURIY) -----
# Kuryer bot a'zo bo'lgan (va admin bo'lgan!) guruhning chat_id.
# `-100...` ko'rinishida — supergroup uchun.
# Aniqlash: kuryer botga guruhdan biror xabar yuborib, log'larda chat_id ko'rinadi.
COURIER_GROUP_CHAT_ID=-1001234567890

# ----- Ma'lumotlar bazasi (MAJBURIY) -----
# Faqat asyncpg driver — `postgresql+asyncpg://...` formatida.
# Production: alohida user, parol bilan; pgbouncer orqali ham bo'lsa OK.
DATABASE_URL=postgresql+asyncpg://delivery:CHANGE_ME@localhost:5432/delivery

# ----- Admin va operator role'lari -----
# Telegram ID'lar (vergul bilan ajratilgan). @userinfobot orqali olishingiz mumkin.
# ADMIN — to'liq huquq (CRUD, settings, broadcasts, finance).
# OPERATOR — faqat "Yangi buyurtma" sahifasi va o'z buyurtmalari ro'yxati.
ADMIN_TELEGRAM_IDS=123456789,987654321
OPERATOR_TELEGRAM_IDS=

# ----- Mini App URL (MAJBURIY production'da, ixtiyoriy local'da) -----
# HTTPS bo'lishi shart (Telegram talab qiladi). Local dev'da ngrok URL.
# @BotFather'da customer va admin botlar uchun /setdomain shu host'ga sozlangan.
# Bo'sh qoldirilsa — Mini App tugmasi bot keyboard'ida ko'rinmaydi (faqat reply menu).
WEBAPP_PUBLIC_URL=https://delivery.example.uz

# ----- Web server -----
# Production'da nginx orqali 8080 portga proxy_pass. Faqat 127.0.0.1 ga bind:
WEBAPP_HOST=0.0.0.0
WEBAPP_PORT=8080

# ----- CORS -----
# Telegram Mini App o'z iframe'ida ishlaydi — odatda bo'sh qoldirsa bo'ladi
# ("*" qo'yiladi, auth Telegram initData orqali — bu xavfsiz).
# Aniq origin'lar: vergul bilan ajratib yozing.
WEBAPP_CORS_ORIGINS=

# ----- Lokalizatsiya / valyuta -----
TIMEZONE=Asia/Tashkent
CURRENCY_SYMBOL=so'm
LOCALE=uz

# ----- Geocoding (xarita qidiruv + ko'cha/uy/mahalla nomlari) -----
# Bepul, kalitsiz, OSM asosida: qidiruv = Photon, teskari = Nominatim.
# Defaultlar ommaviy instanslar — kichik loyiha uchun yetarli.
# PRODUCTION (katta hajm): o'z serveringizda Photon/Nominatim ko'tarib, shu
# URL'larni o'zgartiring (rate-limit/ishonchlilik uchun). Hammasi ixtiyoriy.
# GEOCODE_SEARCH_URL=https://photon.komoot.io/api
# GEOCODE_REVERSE_URL=https://nominatim.openstreetmap.org/reverse
# GEOCODE_USER_AGENT=rbi-water-delivery-bot (Nominatim siyosati uchun; email qo'shing)
# Natijalarni shu nuqtaga moyil qilish (default — Toshkent markazi):
# GEOCODE_BIAS_LAT=41.3111
# GEOCODE_BIAS_LON=69.2797

# ----- Rate limiting -----
# Mini App'da har user (Telegram ID)'ga daqiqada nechta so'rov ruxsat etilgan.
RATE_LIMIT_PER_MINUTE=60

# ----- Logging -----
# DEBUG / INFO / WARNING / ERROR. Production — INFO yoki WARNING tavsiya etiladi.
LOG_LEVEL=INFO

# ----- Diagnostika -----
# Production'da false qoldiring. true bo'lganda `/api/debug/log` endpoint ochiladi
# va frontend (Mini App) GPS sessiyalari va boshqa logs'ni server terminaliga
# yuborishi mumkin. Faqat local debug uchun.
DEBUG_FRONTEND_LOGS=false
